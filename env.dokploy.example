# Dokploy → projeto "databases" → Environment
# Postgres: ligação (túnel PC = mesmos valores). Apps na VPS usam iluminys_db:5432.

DB_HOST=127.0.0.1
DB_PORT=15432
PG_USER=iluminys
PG_PASSWORD=
PG_DB=iluminys

# Redis + MinIO (obrigatório para subir os contentores)
REDIS_PORT=6379
REDIS_HOST_BIND=127.0.0.1
REDIS_MAXMEMORY=256mb

# Igual ao projeto apps (raiz .env / backend) — não usar minioadmin em produção.
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_PORT_BIND=0.0.0.0
MINIO_CONSOLE_PORT_BIND=0.0.0.0
MINIO_BROWSER_REDIRECT_URL=http://69.62.66.153:9001
# Obrigatório para presigned URLs no browser; apps Docker devem usar o MESMO host em MINIO_ENDPOINT.
MINIO_SERVER_URL=http://69.62.66.153:9000
