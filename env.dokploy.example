# Cole no Dokploy → projeto "databases" → aba Environment
# (uma variável por linha; sem aspas no painel)

# --- VPS com dados migrados (use docker-compose.dokploy-vps.yml) ---
TEC_PG_USER=tec
TEC_PG_PASSWORD=
TEC_PG_DB=tecconcursos

# --- Instalação nova (use docker-compose.dokploy.yml) — comente TEC_* e use só PG_* ---
# PG_USER=iluminys
# PG_PASSWORD=
# PG_DB=iluminys

PG_PORT=15432
PG_HOST_BIND=127.0.0.1

REDIS_PORT=6379
REDIS_HOST_BIND=127.0.0.1
REDIS_MAXMEMORY=256mb

MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_PORT_BIND=0.0.0.0
MINIO_CONSOLE_PORT_BIND=0.0.0.0
MINIO_BROWSER_REDIRECT_URL=http://69.62.66.153:9001
MINIO_SERVER_URL=http://69.62.66.153:9000
