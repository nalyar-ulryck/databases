# Copiar para databases/.env (não commitar).
# Mesmos valores que o backend/Dokploy usa para PG_* e MINIO_*.

# Postgres (serviço iluminys_db)
PG_USER=iluminys
PG_PASSWORD=
PG_DB=iluminys
# Porta no host (túnel/migrações). Dentro da rede Docker: iluminys_db:5432
PG_PORT=15432
PG_HOST_BIND=127.0.0.1

# Redis (serviço redis → hostname iluminys_redis na rede)
REDIS_PORT=6379
REDIS_HOST_BIND=127.0.0.1
REDIS_MAXMEMORY=256mb

# MinIO (serviço minio → hostname iluminys_minio na rede)
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
# VPS com acesso externo: 0.0.0.0
MINIO_PORT_BIND=127.0.0.1
MINIO_CONSOLE_PORT_BIND=127.0.0.1
MINIO_BROWSER_REDIRECT_URL=http://127.0.0.1:9001
MINIO_SERVER_URL=http://127.0.0.1:9000
